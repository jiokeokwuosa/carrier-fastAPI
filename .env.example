DATABASE_URL=postgresql+asyncpg://user:password@localhost:26257/carrier?sslmode=disable

UPS_API_BASE_URL=https://wwwcie.ups.com
UPS_OAUTH_URL=https://wwwcie.ups.com/security/v1/oauth/token
UPS_RATING_API_VERSION=v2409
UPS_USERNAME=your_ups_username
UPS_PASSWORD=your_ups_password
UPS_MERCHANT_ID=your_merchant_id
UPS_TRANSACTION_SRC=testing

JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DAYS=7

# Connection pool (PostgreSQL / CockroachDB)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Optional Redis for carrier OAuth token caching
# REDIS_URL=redis://localhost:6379/0
